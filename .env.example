# plugin-frigate plugin environment
# Runtime values are loaded from test/config/plugins/plugin-frigate/.env(.local)
# or from process environment (docker-compose environment/env_file).

PLUGIN_FRIGATE_ENABLED=true
PLUGIN_FRIGATE_LOG_LEVEL=info
FRIGATE_URL=
FRIGATE_GO2RTC_URL=

# Optional MQTT input (for HA-style occupancy/count/status semantics)
FRIGATE_MQTT_HOST=
FRIGATE_MQTT_PORT=1883
FRIGATE_MQTT_USER=
FRIGATE_MQTT_PASSWORD=
FRIGATE_MQTT_TOPIC_PREFIX=frigate
