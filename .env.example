# plugin-frigate environment
# For local discovery mode, only PLUGIN_DATA_DIR is required.
# Camera discovery requires Frigate URL configuration.
# Copy to .env.local and customize with real values.

# Required: Directory for plugin state storage
PLUGIN_DATA_DIR=/tmp/plugin-frigate

# Required for camera discovery: Frigate instance URL
# Without this, discovery runs but no cameras will be found
FRIGATE_URL=http://frigate.local:5000

# Optional: go2rtc URL for WebRTC streaming (defaults to FRIGATE_URL)
FRIGATE_GO2RTC_URL=

# Optional: externally reachable base URLs used in emitted stream/image entity URLs.
# Use these when internal Frigate/go2rtc endpoints (e.g. 127.0.0.1) are not
# reachable by clients consuming Slidebolt stream URLs.
FRIGATE_PUBLIC_URL=
FRIGATE_GO2RTC_PUBLIC_URL=

# Optional: MQTT input for HA-style occupancy/count/status semantics
FRIGATE_MQTT_HOST=
FRIGATE_MQTT_PORT=1883
FRIGATE_MQTT_USER=
FRIGATE_MQTT_PASSWORD=
FRIGATE_MQTT_TOPIC_PREFIX=frigate
